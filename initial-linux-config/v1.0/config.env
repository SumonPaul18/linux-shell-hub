# =============================================================================
# config.env - Production Server Configuration
# =============================================================================

# --- User Management ---
NEW_USERNAME="sumon"

# Option 1: Password Authentication
# Set a strong password here. If left empty, password auth will be disabled (unless SSH Key is also missing).
# Security Note: In production, prefer SSH Keys.
NEW_USER_PASSWORD="" 

# Option 2: SSH Key Authentication
# Paste your full public key content here (starts with ssh-rsa or ssh-ed25519).
# If provided, this key will be added to authorized_keys.
# Example: SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@host"
SSH_PUBLIC_KEY=""

# --- Network Configuration ---
SERVER_HOSTNAME="cloud3-prod"
DOMAIN="paulco.xyz"

# Static IP settings (CIDR notation)
STATIC_IP_CIDR="192.168.0.63/24"
GATEWAY="192.168.0.1"
DNS_SERVERS="8.8.8.8,1.1.1.1"

# Network Interface (Leave empty for auto-detection)
NETWORK_INTERFACE="" 

# --- System Settings ---
TIMEZONE="Asia/Dhaka"

# Packages to install (Essential for Ansible & Monitoring)
# 'python3' and 'ssh' are critical for Ansible connectivity
PACKAGES_TO_INSTALL="git curl wget vim htop net-tools python3 python3-pip software-properties-common ufw fail2ban unattended-upgrades"

# --- Security Toggles ---
# Set to 'yes' to disable Root Login via SSH (Recommended for Production)
DISABLE_ROOT_LOGIN="yes"

# Set to 'yes' to disable Password Authentication globally (Only if SSH Key is provided)
# If both Password and Key are provided, this will be set to 'no' to allow both methods.
FORCE_KEY_ONLY="no"
