# =============================================================================
# config.env - Advanced Production Server Configuration
# Edit this file before running setup-prod-server.sh
# =============================================================================

# --- 1. User Management ---
NEW_USERNAME="sumon"

# Option A: Password Authentication
# Set a password here. If left empty ("") and no SSH Key is provided, a random one will be generated.
NEW_USER_PASSWORD=""

# Option B: SSH Key Authentication
# Paste your full public key content here (starts with ssh-rsa or ssh-ed25519).
# Example: SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@host"
# Leave empty ("") if you only want to use Password.
SSH_PUBLIC_KEY=""

# Sudo Configuration
# Set to "yes" to allow passwordless sudo (Recommended for Ansible)
# Set to "no" to require password for sudo commands
PASSWORDLESS_SUDO="yes"

# --- 2. Network Configuration ---
SERVER_HOSTNAME="cloud3-prod"
DOMAIN="paulco.xyz"

STATIC_IP_CIDR="192.168.0.63/24"
GATEWAY="192.168.0.1"
DNS_SERVERS="8.8.8.8,1.1.1.1"

# Network Interface (Leave empty "" for auto-detection)
NETWORK_INTERFACE=""

# --- 3. SSH Hardening Settings ---
# Control these settings directly from here. Values: "yes", "no", "prohibit-password", "without-password"

# PermitRootLogin: "no" (secure), "yes" (insecure), "prohibit-password" (key-only root login)
SSH_PERMIT_ROOT_LOGIN="no"

# PasswordAuthentication: "yes" (allow pass), "no" (key-only)
# Script logic: If NEW_USER_PASSWORD is empty, this will be forced to "no" regardless of this setting.
SSH_PASSWORD_AUTHENTICATION="yes"

# PubkeyAuthentication: "yes" (recommended), "no"
SSH_PUBKEY_AUTHENTICATION="yes"

# PermitEmptyPasswords: Should always be "no" for security
SSH_PERMIT_EMPTY_PASSWORDS="no"

# Additional Hardening Options
SSH_X11_FORWARDING="no"
SSH_CLIENT_ALIVE_INTERVAL="300"
SSH_CLIENT_ALIVE_COUNT_MAX="2"
SSH_MAX_AUTH_TRIES="4"

# --- 4. Security Tools Toggle ---
# Enable or disable firewall and intrusion detection
ENABLE_UFW="yes"
ENABLE_FAIL2BAN="yes"

# --- 5. System Settings ---
TIMEZONE="Asia/Dhaka"

# Packages to install (Essential for Ansible & Monitoring)
PACKAGES_TO_INSTALL="git curl wget vim htop net-tools python3 python3-pip software-properties-common"